{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arena",
  "version": "1.0.0",
  "identifier": "cn.neurolab.arena",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "arena",
        "width": 1440,
        "height": 1000,
        "minWidth": 1152,
        "minHeight": 800,
        "maxWidth": 1440,
        "maxHeight": 1000,
        "decorations": false,
        "resizable": false,
        "maximizable": true,
        "center": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "resources": ["../protocols", "../RpiBeh_repo/client_host", "../backend-dist/arena-backend/arena-backend.exe"]
  }
}
